# Ignore environment variables
.env

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore build folders
dist/
build/
rsconnect/
data/*.gz
data/*.tbi
*.Rhistory
.Rproj.user/

# Ignore log files
*.log

# --- Manuscript & internal review materials (never push to public mirror) ---
# These contain in-review manuscript drafts, reviewer comments, revision plans,
# and cover-letter responses. Keep local; do not commit to any public remote.
*.docx
*.pdf
docs/plans/
docs/cover-letter-*.md
varviz-research.md
varviz-humanized-research.md
clinvar_debug_raw.json

# --- Pass 2 analysis artifacts (regeneratable; never push to public mirror) ---
analyses/raw/
analyses/derived/
analyses/classifications/
analyses/figures/
analyses/reports/
# Keep tracked: analyses/*.R, analyses/lib/*.R, analyses/manifests/*.json

# AlphaMissense per-substitution CSVs cached at the project root by the
# harness (one per UniProt accession; tens of thousands of rows each).
# Regeneratable from https://alphafold.ebi.ac.uk/files/AF-<UID>-F1-aa-substitutions.csv
[A-Z][0-9]*-F1-aa-substitutions.csv
